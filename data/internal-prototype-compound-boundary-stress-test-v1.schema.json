{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hoax.ai/schemas/internal-prototype-compound-boundary-stress-test-v1.schema.json",
  "title": "Internal Prototype Compound Boundary Stress Test v1",
  "type": "object",
  "required": [
    "stress_test_id",
    "version",
    "status",
    "decision_ref",
    "sprint",
    "public_route_authorized",
    "public_benchmark_authorized",
    "public_report_authorized",
    "output_generator_authorized",
    "scoring_authorized",
    "api_authorized",
    "javascript_authorized",
    "source_authority",
    "compound_boundary_classes",
    "stress_cases",
    "collapse_prevention_rules",
    "forbidden_transformations",
    "required_stress_result_fields",
    "failure_conditions",
    "operational_boundaries"
  ],
  "properties": {
    "stress_test_id": {
      "type": "string",
      "const": "internal-prototype-compound-boundary-stress-test-v1"
    },
    "version": { "type": "string" },
    "status": {
      "type": "string",
      "const": "internal_non_public_compound_boundary_stress_test"
    },
    "decision_ref": {
      "type": "string",
      "const": "DEC-095"
    },
    "sprint": {
      "type": "string",
      "const": "Sprint 77"
    },
    "public_route_authorized": { "type": "boolean", "const": false },
    "public_benchmark_authorized": { "type": "boolean", "const": false },
    "public_report_authorized": { "type": "boolean", "const": false },
    "output_generator_authorized": { "type": "boolean", "const": false },
    "scoring_authorized": { "type": "boolean", "const": false },
    "api_authorized": { "type": "boolean", "const": false },
    "javascript_authorized": { "type": "boolean", "const": false },
    "source_authority": { "type": "array", "minItems": 7 },
    "compound_boundary_classes": { "type": "array", "minItems": 8 },
    "stress_cases": { "type": "array", "minItems": 8 },
    "collapse_prevention_rules": { "type": "array", "minItems": 5 },
    "forbidden_transformations": { "type": "array", "minItems": 5 },
    "required_stress_result_fields": { "type": "array", "minItems": 10 },
    "failure_conditions": { "type": "array", "minItems": 8 },
    "operational_boundaries": {
      "type": "object",
      "required": [
        "no_public_benchmark",
        "no_public_report",
        "no_public_engine",
        "no_output_generator",
        "no_upload",
        "no_scoring",
        "no_api",
        "no_javascript",
        "no_public_tool_behavior"
      ],
      "properties": {
        "no_public_benchmark": { "type": "boolean", "const": true },
        "no_public_report": { "type": "boolean", "const": true },
        "no_public_engine": { "type": "boolean", "const": true },
        "no_output_generator": { "type": "boolean", "const": true },
        "no_upload": { "type": "boolean", "const": true },
        "no_scoring": { "type": "boolean", "const": true },
        "no_api": { "type": "boolean", "const": true },
        "no_javascript": { "type": "boolean", "const": true },
        "no_public_tool_behavior": { "type": "boolean", "const": true }
      }
    }
  },
  "additionalProperties": true
}
