{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hoax.ai/schemas/public-exposure-prerequisite-map-v1.schema.json",
  "title": "Public Exposure Prerequisite Map v1",
  "type": "object",
  "required": [
    "prerequisite_map_id",
    "version",
    "status",
    "decision_ref",
    "sprint",
    "public_exposure_authorized",
    "blocker_clearance_authorized",
    "release_authorized",
    "public_route_authorized",
    "public_benchmark_authorized",
    "public_report_authorized",
    "output_generator_authorized",
    "input_system_authorized",
    "upload_authorized",
    "scoring_authorized",
    "api_authorized",
    "javascript_authorized",
    "monetization_authorized",
    "source_authority",
    "prerequisite_domains",
    "prerequisites",
    "prohibited_shortcuts",
    "clearance_pathway_rules",
    "non_authorization_statement",
    "operational_boundaries"
  ],
  "properties": {
    "prerequisite_map_id": {
      "type": "string",
      "const": "public-exposure-prerequisite-map-v1"
    },
    "version": { "type": "string" },
    "status": {
      "type": "string",
      "const": "internal_non_public_public_exposure_prerequisite_map"
    },
    "decision_ref": {
      "type": "string",
      "const": "DEC-100"
    },
    "sprint": {
      "type": "string",
      "const": "Sprint 82"
    },
    "public_exposure_authorized": { "type": "boolean", "const": false },
    "blocker_clearance_authorized": { "type": "boolean", "const": false },
    "release_authorized": { "type": "boolean", "const": false },
    "public_route_authorized": { "type": "boolean", "const": false },
    "public_benchmark_authorized": { "type": "boolean", "const": false },
    "public_report_authorized": { "type": "boolean", "const": false },
    "output_generator_authorized": { "type": "boolean", "const": false },
    "input_system_authorized": { "type": "boolean", "const": false },
    "upload_authorized": { "type": "boolean", "const": false },
    "scoring_authorized": { "type": "boolean", "const": false },
    "api_authorized": { "type": "boolean", "const": false },
    "javascript_authorized": { "type": "boolean", "const": false },
    "monetization_authorized": { "type": "boolean", "const": false },
    "source_authority": { "type": "array", "minItems": 5 },
    "prerequisite_domains": { "type": "array", "minItems": 21 },
    "prerequisites": { "type": "array", "minItems": 24 },
    "prohibited_shortcuts": { "type": "array", "minItems": 10 },
    "clearance_pathway_rules": { "type": "array", "minItems": 5 },
    "non_authorization_statement": { "type": "string" },
    "operational_boundaries": {
      "type": "object",
      "required": [
        "no_public_route",
        "no_public_report",
        "no_public_engine",
        "no_output_generator",
        "no_input_system",
        "no_upload",
        "no_scoring",
        "no_api",
        "no_javascript",
        "no_public_tool_behavior"
      ],
      "properties": {
        "no_public_route": { "type": "boolean", "const": true },
        "no_public_report": { "type": "boolean", "const": true },
        "no_public_engine": { "type": "boolean", "const": true },
        "no_output_generator": { "type": "boolean", "const": true },
        "no_input_system": { "type": "boolean", "const": true },
        "no_upload": { "type": "boolean", "const": true },
        "no_scoring": { "type": "boolean", "const": true },
        "no_api": { "type": "boolean", "const": true },
        "no_javascript": { "type": "boolean", "const": true },
        "no_public_tool_behavior": { "type": "boolean", "const": true }
      }
    }
  }
}
