{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hoax.ai/schemas/public-reference-retrieval-walkthrough-audit-v1.schema.json",
  "title": "Public Reference Retrieval Walkthrough Audit v1",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "sprint",
    "status",
    "audit_only",
    "production_route_added",
    "public_route_count_before",
    "public_route_count_after",
    "sitemap_url_count_expected",
    "primary_route_under_audit",
    "related_routes_checked",
    "walkthrough_scenarios",
    "total_scenarios",
    "scenarios_passed",
    "scenarios_failed",
    "repairs_applied",
    "boundary_regressions_found",
    "new_decision_created",
    "route_registry_changed",
    "public_file_registry_changed",
    "sitemap_changed",
    "no_new_routes",
    "non_search",
    "non_ranking",
    "non_generated_answer",
    "non_verdict",
    "non_scoring",
    "non_detector",
    "non_workflow",
    "non_operational",
    "non_transactional_review_surface"
  ],
  "properties": {
    "id": { "const": "public-reference-retrieval-walkthrough-audit-v1" },
    "sprint": { "const": "Sprint 119" },
    "status": { "const": "public_reference_retrieval_walkthrough_audit" },
    "audit_only": { "const": true },
    "production_route_added": { "const": false },
    "public_route_count_before": { "const": 102 },
    "public_route_count_after": { "const": 102 },
    "sitemap_url_count_expected": { "const": 102 },
    "primary_route_under_audit": { "const": "/retrieval-index/" },
    "walkthrough_scenarios": { "type": "array", "minItems": 15 },
    "total_scenarios": { "type": "integer", "minimum": 15 },
    "scenarios_passed": { "type": "integer", "minimum": 0 },
    "scenarios_failed": { "type": "integer", "minimum": 0 },
    "new_decision_created": { "type": "boolean" },
    "route_registry_changed": { "const": false },
    "public_file_registry_changed": { "const": false },
    "no_new_routes": { "const": true }
  }
}
