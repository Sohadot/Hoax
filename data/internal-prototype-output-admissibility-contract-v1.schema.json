{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hoax.ai/schemas/internal-prototype-output-admissibility-contract-v1.schema.json",
  "title": "Internal Prototype Output Admissibility Contract v1",
  "type": "object",
  "required": [
    "contract_id",
    "version",
    "status",
    "decision_ref",
    "sprint",
    "public_route_authorized",
    "public_benchmark_authorized",
    "public_report_authorized",
    "output_generator_authorized",
    "scoring_authorized",
    "api_authorized",
    "javascript_authorized",
    "source_authority",
    "admissibility_requirements",
    "admissibility_status_vocabulary",
    "inadmissibility_conditions",
    "repair_policy",
    "required_internal_result_fields",
    "forbidden_output_shapes",
    "non_public_boundary",
    "operational_boundaries"
  ],
  "properties": {
    "contract_id": {
      "type": "string",
      "const": "internal-prototype-output-admissibility-contract-v1"
    },
    "version": { "type": "string" },
    "status": {
      "type": "string",
      "const": "internal_non_public_output_admissibility_contract"
    },
    "decision_ref": {
      "type": "string",
      "const": "DEC-097"
    },
    "sprint": {
      "type": "string",
      "const": "Sprint 79"
    },
    "public_route_authorized": { "type": "boolean", "const": false },
    "public_benchmark_authorized": { "type": "boolean", "const": false },
    "public_report_authorized": { "type": "boolean", "const": false },
    "output_generator_authorized": { "type": "boolean", "const": false },
    "scoring_authorized": { "type": "boolean", "const": false },
    "api_authorized": { "type": "boolean", "const": false },
    "javascript_authorized": { "type": "boolean", "const": false },
    "source_authority": { "type": "array", "minItems": 7 },
    "admissibility_requirements": { "type": "array", "minItems": 15 },
    "admissibility_status_vocabulary": { "type": "array", "minItems": 8 },
    "inadmissibility_conditions": { "type": "array", "minItems": 15 },
    "repair_policy": { "type": "array", "minItems": 5 },
    "required_internal_result_fields": { "type": "array", "minItems": 15 },
    "forbidden_output_shapes": { "type": "array", "minItems": 5 },
    "non_public_boundary": { "type": "string", "minLength": 20 },
    "operational_boundaries": {
      "type": "object",
      "required": [
        "no_public_benchmark",
        "no_public_report",
        "no_public_engine",
        "no_output_generator",
        "no_upload",
        "no_scoring",
        "no_api",
        "no_javascript",
        "no_public_tool_behavior"
      ],
      "properties": {
        "no_public_benchmark": { "type": "boolean", "const": true },
        "no_public_report": { "type": "boolean", "const": true },
        "no_public_engine": { "type": "boolean", "const": true },
        "no_output_generator": { "type": "boolean", "const": true },
        "no_upload": { "type": "boolean", "const": true },
        "no_scoring": { "type": "boolean", "const": true },
        "no_api": { "type": "boolean", "const": true },
        "no_javascript": { "type": "boolean", "const": true },
        "no_public_tool_behavior": { "type": "boolean", "const": true }
      }
    }
  }
}
