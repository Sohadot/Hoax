{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hoax.ai/schemas/output-language-guardrail-model-v1.schema.json",
  "title": "Output Language Guardrail Model v1",
  "type": "object",
  "required": [
    "guardrail_id",
    "version",
    "status",
    "decision_ref",
    "sprint",
    "public_route_authorized",
    "public_output_generator_authorized",
    "public_engine_authorized",
    "classifier_authorized",
    "scoring_authorized",
    "api_authorized",
    "javascript_authorized",
    "linguistic_primitives",
    "allowed_output_families",
    "prohibited_output_families",
    "posture_state_language_rules",
    "required_caveat_rules",
    "forbidden_term_controls",
    "boundary_transformation_rules",
    "failure_modes",
    "operational_boundaries"
  ],
  "properties": {
    "guardrail_id": {
      "type": "string",
      "const": "output-language-guardrail-model-v1"
    },
    "version": { "type": "string" },
    "status": {
      "type": "string",
      "const": "internal_non_operational_guardrail_model"
    },
    "decision_ref": {
      "type": "string",
      "const": "DEC-087"
    },
    "sprint": {
      "type": "string",
      "const": "Sprint 69"
    },
    "public_route_authorized": { "type": "boolean", "const": false },
    "public_output_generator_authorized": { "type": "boolean", "const": false },
    "public_engine_authorized": { "type": "boolean", "const": false },
    "classifier_authorized": { "type": "boolean", "const": false },
    "scoring_authorized": { "type": "boolean", "const": false },
    "api_authorized": { "type": "boolean", "const": false },
    "javascript_authorized": { "type": "boolean", "const": false },
    "linguistic_primitives": {
      "type": "array",
      "minItems": 12,
      "items": {
        "type": "object",
        "required": [
          "primitive_id",
          "name",
          "definition",
          "function",
          "allowed_use",
          "forbidden_misuse",
          "standard_relation",
          "protocol_relation",
          "engine_model_relation"
        ]
      }
    },
    "allowed_output_families": {
      "type": "array",
      "minItems": 14
    },
    "prohibited_output_families": {
      "type": "array",
      "allOf": [
        { "contains": { "const": "fake/real verdict" } },
        { "contains": { "const": "truth/falsity verdict" } },
        { "contains": { "const": "subject guilt" } },
        { "contains": { "const": "deception finding" } },
        { "contains": { "const": "manipulation proof" } },
        { "contains": { "const": "fraud accusation" } },
        { "contains": { "const": "numeric score" } },
        { "contains": { "const": "confidence percentage" } },
        { "contains": { "const": "upload classification result" } }
      ]
    },
    "posture_state_language_rules": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["posture_state"],
        "properties": {
          "posture_state": {
            "enum": ["Supported", "Qualified", "Limited", "Not Assessable", "Out of Scope"]
          }
        }
      }
    },
    "required_caveat_rules": {
      "type": "array",
      "minItems": 9
    },
    "forbidden_term_controls": {
      "type": "object",
      "required": ["forbidden_as_output_conclusions", "allowed_only_as_prohibited_examples"]
    },
    "boundary_transformation_rules": {
      "type": "array",
      "minItems": 6
    },
    "failure_modes": {
      "type": "array",
      "minItems": 8
    },
    "operational_boundaries": {
      "type": "object",
      "required": [
        "no_public_engine",
        "no_output_generator",
        "no_upload",
        "no_scoring",
        "no_api",
        "no_javascript",
        "no_public_tool_behavior"
      ],
      "properties": {
        "no_public_engine": { "const": true },
        "no_output_generator": { "const": true },
        "no_upload": { "const": true },
        "no_scoring": { "const": true },
        "no_api": { "const": true },
        "no_javascript": { "const": true },
        "no_public_tool_behavior": { "const": true }
      }
    }
  },
  "additionalProperties": true
}
