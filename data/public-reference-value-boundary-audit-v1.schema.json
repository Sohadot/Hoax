{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hoax.ai/schemas/public-reference-value-boundary-audit-v1.schema.json",
  "title": "Public Reference Value Boundary Audit v1",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "sprint",
    "status",
    "audit_only",
    "phase",
    "phase_entry_audit",
    "production_route_added",
    "public_route_count_before",
    "public_route_count_after",
    "sitemap_url_count_expected",
    "value_language_inventory",
    "total_value_language_inventory_count",
    "walkthrough_scenarios",
    "total_scenarios",
    "scenarios_passed",
    "scenarios_failed",
    "value_boundary_confirmed",
    "new_decision_created",
    "route_registry_changed",
    "public_file_registry_changed",
    "no_new_routes"
  ],
  "properties": {
    "id": { "const": "public-reference-value-boundary-audit-v1" },
    "sprint": { "const": "Sprint 129" },
    "status": { "const": "public_reference_value_boundary_audit" },
    "audit_only": { "const": true },
    "phase": { "const": "Phase 4" },
    "phase_entry_audit": { "const": true },
    "production_route_added": { "const": false },
    "public_route_count_before": { "const": 104 },
    "public_route_count_after": { "const": 104 },
    "sitemap_url_count_expected": { "const": 104 },
    "value_language_inventory": { "type": "array", "minItems": 30 },
    "total_value_language_inventory_count": { "type": "integer", "minimum": 30 },
    "walkthrough_scenarios": { "type": "array", "minItems": 28 },
    "total_scenarios": { "type": "integer", "minimum": 28 },
    "value_boundary_confirmed": { "const": true },
    "new_decision_created": { "type": "boolean" },
    "route_registry_changed": { "const": false },
    "public_file_registry_changed": { "const": false },
    "no_new_routes": { "const": true }
  }
}
