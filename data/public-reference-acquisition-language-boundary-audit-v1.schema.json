{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hoax.ai/schemas/public-reference-acquisition-language-boundary-audit-v1.schema.json",
  "title": "Public Reference Acquisition Language Boundary Audit v1",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "sprint",
    "status",
    "audit_only",
    "production_route_added",
    "public_route_count_before",
    "public_route_count_after",
    "sitemap_url_count_expected",
    "acquisition_language_inventory",
    "total_language_inventory_count",
    "safe_language_count",
    "repaired_language_count",
    "unsafe_language_count",
    "walkthrough_scenarios",
    "total_scenarios",
    "scenarios_passed",
    "scenarios_failed",
    "new_decision_created",
    "route_registry_changed",
    "public_file_registry_changed",
    "no_new_routes",
    "acquisition_language_boundary_confirmed"
  ],
  "properties": {
    "id": { "const": "public-reference-acquisition-language-boundary-audit-v1" },
    "sprint": { "const": "Sprint 127" },
    "status": { "const": "public_reference_acquisition_language_boundary_audit" },
    "audit_only": { "const": true },
    "production_route_added": { "const": false },
    "public_route_count_before": { "const": 104 },
    "public_route_count_after": { "const": 104 },
    "sitemap_url_count_expected": { "const": 104 },
    "acquisition_language_inventory": { "type": "array", "minItems": 25 },
    "total_language_inventory_count": { "type": "integer", "minimum": 25 },
    "walkthrough_scenarios": { "type": "array", "minItems": 24 },
    "total_scenarios": { "type": "integer", "minimum": 24 },
    "new_decision_created": { "type": "boolean" },
    "route_registry_changed": { "const": false },
    "public_file_registry_changed": { "const": false },
    "no_new_routes": { "const": true }
  }
}
