{
  "policy_id": "INT-DRAFT-PACK-POLICY-001",
  "name": "Hoax.ai Internal Draft Pack Policy",
  "version": "v1.0.0",
  "status": "governed_internal_draft_pack_policy",
  "maturity": "internal_drafts_only_no_routes_no_sitemap_no_publication",
  "governing_principle": "An internal draft may contain prose. It must not become a public surface.",
  "discipline_principle": "The first drafts must prove reference discipline, not publication speed.",
  "allowed_internal_draft_actions": [
    "internal_draft_file_creation_for_approved_blueprint_records_only",
    "internal_draft_prose_creation",
    "section_compliance_validation",
    "claim_scope_discipline",
    "source_scope_discipline",
    "semantic_seo_restraint_planning"
  ],
  "prohibited_internal_draft_actions": [
    "public_page_creation",
    "route_activation",
    "sitemap_expansion",
    "public_metadata",
    "public_navigation",
    "publication",
    "deployment",
    "dns",
    "cloudflare",
    "tool",
    "classifier",
    "upload",
    "scoring",
    "forms",
    "analytics",
    "external_factual_claims"
  ],
  "required_draft_fields": [
    "draft_id",
    "candidate_id",
    "candidate_name",
    "blueprint_id",
    "draft_file_path",
    "draft_status",
    "route_status",
    "sitemap_status",
    "publication_status",
    "public_metadata_status",
    "public_navigation_status",
    "deployment_status",
    "page_family",
    "page_type_ref",
    "template_ref",
    "reference_thesis",
    "claim_scope",
    "source_scope",
    "semantic_seo_role",
    "required_sections",
    "required_gates",
    "non_authorization_statement",
    "review_status",
    "notes"
  ],
  "required_draft_sections": [
    "Draft Status Block",
    "Draft Thesis",
    "Definition and Scope",
    "Governance Boundary",
    "Relationship to Hoax.ai System",
    "Semantic SEO Role",
    "Claim and Source Traceability",
    "Prohibited Misreadings",
    "Internal Link Plan",
    "Structured Data Boundary",
    "Review Status",
    "Non-Authorization Statement"
  ],
  "required_status_values": {
    "draft_status": "internal_draft_created",
    "route_status": "not_route_created",
    "sitemap_status": "not_sitemap_eligible",
    "publication_status": "publication_blocked",
    "public_metadata_status": "not_created",
    "public_navigation_status": "not_linked",
    "deployment_status": "not_deployed"
  },
  "draft_location_policy": "_internal_drafts/reference/",
  "non_authorization_rules": [
    "internal_drafts_do_not_authorize_routes",
    "internal_drafts_do_not_authorize_sitemap",
    "internal_drafts_do_not_authorize_public_pages",
    "internal_drafts_do_not_authorize_public_metadata",
    "internal_drafts_do_not_authorize_publishing",
    "internal_drafts_do_not_authorize_deployment",
    "internal_drafts_do_not_authorize_seo_expansion",
    "no_numeric_score_grade_percentage_or_seo_score"
  ],
  "last_reviewed": "2026-06-17"
}
