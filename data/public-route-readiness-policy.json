{
  "policy_id": "PUB-ROUTE-READINESS-POLICY-001",
  "name": "Hoax.ai Public Route Readiness Policy",
  "version": "v1.0.0",
  "status": "governed_public_route_readiness_policy",
  "maturity": "readiness_gate_only_no_routes_no_sitemap_no_publication",
  "governing_principle": "Route readiness is not route creation.",
  "boundary_principle": "A draft may become eligible for public conversion only when its boundaries are stronger than its visibility.",
  "allowed_readiness_actions": [
    "readiness_record_creation",
    "inactive_route_candidate_record_creation",
    "proposed_path_safety_review",
    "route_registry_conflict_check",
    "sitemap_non_expansion_verification",
    "validation_only"
  ],
  "prohibited_readiness_actions": [
    "public_page_creation",
    "route_activation",
    "sitemap_expansion",
    "public_metadata",
    "public_navigation",
    "publication",
    "deployment",
    "dns",
    "cloudflare",
    "tool",
    "classifier",
    "upload",
    "scoring",
    "forms",
    "analytics",
    "api",
    "monetization",
    "external_factual_claims"
  ],
  "readiness_scope": ["DRAFT-0001", "DRAFT-0002"],
  "readiness_outcomes": [
    "route_readiness_passed_internal",
    "route_readiness_passed_with_conditions",
    "needs_minor_route_preparation",
    "needs_major_route_preparation",
    "blocked_for_boundary_issue",
    "blocked_for_claim_source_issue",
    "blocked_for_public_implication",
    "blocked_for_route_conflict"
  ],
  "proposed_route_path_policy": "Inactive candidate paths only. Proposed paths /reference/evidence-posture/ and /reference/artifact-subject-separation/ may be recorded internally but must not be added to active route registry or sitemap.",
  "metadata_policy": "Sprint 23 forbids public title, meta description, canonical, schema, Open Graph, and Twitter metadata creation. Internal future requirements may be described only.",
  "non_authorization_rules": [
    "readiness_does_not_authorize_routes",
    "readiness_does_not_authorize_sitemap",
    "readiness_does_not_authorize_public_pages",
    "readiness_does_not_authorize_public_metadata",
    "readiness_does_not_authorize_public_navigation",
    "readiness_does_not_authorize_publishing",
    "readiness_does_not_authorize_deployment",
    "readiness_does_not_authorize_seo_expansion",
    "readiness_does_not_authorize_classifier",
    "readiness_does_not_authorize_tool",
    "readiness_does_not_authorize_upload_workflow"
  ],
  "last_reviewed": "2026-06-17"
}
