{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Public Reference Navigation IA Consolidation v1",
  "type": "object",
  "required": [
    "ia_id",
    "decision_ref",
    "sprint",
    "status",
    "production_first",
    "governance_after_production",
    "new_public_routes_added",
    "expected_sitemap_url_count_after",
    "expected_route_registry_count_after",
    "human_readable",
    "ai_readable",
    "ia_consolidated",
    "route_groups",
    "pages_updated_minimum",
    "required_components",
    "upload_authorized",
    "scoring_authorized",
    "verdict_authorized",
    "detector_claim_authorized",
    "public_api_authorized",
    "automated_report_authorized",
    "javascript_authorized",
    "forms_authorized",
    "real_world_case_evaluation_authorized",
    "chatbot_authorized",
    "generator_authorized"
  ],
  "properties": {
    "ia_id": { "const": "public-reference-navigation-ia-consolidation-v1" },
    "decision_ref": { "const": "DEC-112" },
    "sprint": { "const": "Sprint 94" },
    "status": { "const": "public_reference_navigation_ia_consolidation" },
    "production_first": { "const": true },
    "governance_after_production": { "const": true },
    "new_public_routes_added": { "const": false },
    "expected_sitemap_url_count_after": { "const": 41 },
    "expected_route_registry_count_after": { "const": 41 },
    "human_readable": { "const": true },
    "ai_readable": { "const": true },
    "ia_consolidated": { "const": true },
    "route_groups": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "uniqueItems": true
    },
    "pages_updated_minimum": { "minimum": 23 },
    "required_components": {
      "type": "array",
      "minItems": 6,
      "contains": { "enum": [
        "homepage_ia_section",
        "page_role_label",
        "system_navigation_block",
        "where_to_go_next_refinement",
        "pathway_entry_points",
        "ia_capsule"
      ]}
    },
    "upload_authorized": { "const": false },
    "scoring_authorized": { "const": false },
    "verdict_authorized": { "const": false },
    "detector_claim_authorized": { "const": false },
    "public_api_authorized": { "const": false },
    "automated_report_authorized": { "const": false },
    "javascript_authorized": { "const": false },
    "forms_authorized": { "const": false },
    "real_world_case_evaluation_authorized": { "const": false },
    "chatbot_authorized": { "const": false },
    "generator_authorized": { "const": false }
  },
  "additionalProperties": true
}
