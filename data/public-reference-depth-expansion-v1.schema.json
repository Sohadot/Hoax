{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Public Reference Depth Expansion v1",
  "type": "object",
  "required": [
    "expansion_id",
    "decision_ref",
    "sprint",
    "status",
    "production_first",
    "governance_after_production",
    "new_public_routes_added",
    "expected_sitemap_url_count_after",
    "expected_route_registry_count_after",
    "public_routes_added",
    "minimum_visible_words_per_new_route",
    "required_components",
    "human_readable",
    "ai_readable",
    "citation_safe",
    "retrieval_hardened",
    "reference_depth_expansion",
    "upload_authorized",
    "scoring_authorized",
    "verdict_authorized",
    "detector_claim_authorized",
    "public_api_authorized",
    "automated_report_authorized",
    "javascript_authorized",
    "forms_authorized",
    "real_world_case_evaluation_authorized",
    "chatbot_authorized",
    "generator_authorized"
  ],
  "properties": {
    "expansion_id": { "const": "public-reference-depth-expansion-v1" },
    "decision_ref": { "const": "DEC-110" },
    "sprint": { "const": "Sprint 92" },
    "status": { "const": "public_reference_depth_expansion" },
    "production_first": { "const": true },
    "governance_after_production": { "const": true },
    "new_public_routes_added": { "const": true },
    "expected_sitemap_url_count_after": { "const": 35 },
    "expected_route_registry_count_after": { "const": 35 },
    "public_routes_added": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "uniqueItems": true
    },
    "minimum_visible_words_per_new_route": { "const": 900 },
    "required_components": {
      "type": "array",
      "minItems": 9,
      "contains": { "enum": [
        "reference_summary",
        "reference_answer",
        "source_confidence",
        "reference_path",
        "related_concepts",
        "cite_this_reference",
        "retrieval_capsule",
        "page_end_reference_navigation",
        "boundary_reminder"
      ]}
    },
    "human_readable": { "const": true },
    "ai_readable": { "const": true },
    "citation_safe": { "const": true },
    "retrieval_hardened": { "const": true },
    "reference_depth_expansion": { "const": true },
    "upload_authorized": { "const": false },
    "scoring_authorized": { "const": false },
    "verdict_authorized": { "const": false },
    "detector_claim_authorized": { "const": false },
    "public_api_authorized": { "const": false },
    "automated_report_authorized": { "const": false },
    "javascript_authorized": { "const": false },
    "forms_authorized": { "const": false },
    "real_world_case_evaluation_authorized": { "const": false },
    "chatbot_authorized": { "const": false },
    "generator_authorized": { "const": false }
  },
  "additionalProperties": true
}
