{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hoax.ai/schemas/public-reference-non-transactional-revenue-boundary-audit-v1.schema.json",
  "title": "Public Reference Non-Transactional Revenue Boundary Audit v1",
  "type": "object",
  "required": [
    "id", "name", "version", "sprint", "status", "audit_only", "phase", "phase_boundary_audit",
    "production_route_added", "public_route_count_before", "public_route_count_after",
    "sitemap_url_count_expected", "revenue_boundary_language_inventory",
    "total_revenue_boundary_language_inventory_count", "walkthrough_scenarios",
    "total_scenarios", "scenarios_passed", "scenarios_failed",
    "non_transactional_revenue_boundary_confirmed", "new_decision_created",
    "route_registry_changed", "public_file_registry_changed", "no_new_routes"
  ],
  "properties": {
    "id": { "const": "public-reference-non-transactional-revenue-boundary-audit-v1" },
    "sprint": { "const": "Sprint 130" },
    "status": { "const": "public_reference_non_transactional_revenue_boundary_audit" },
    "audit_only": { "const": true },
    "phase": { "const": "Phase 4" },
    "phase_boundary_audit": { "const": true },
    "production_route_added": { "const": false },
    "public_route_count_before": { "const": 104 },
    "public_route_count_after": { "const": 104 },
    "sitemap_url_count_expected": { "const": 104 },
    "revenue_boundary_language_inventory": { "type": "array", "minItems": 32 },
    "walkthrough_scenarios": { "type": "array", "minItems": 32 },
    "non_transactional_revenue_boundary_confirmed": { "const": true },
    "new_decision_created": { "type": "boolean" },
    "no_new_routes": { "const": true }
  }
}
