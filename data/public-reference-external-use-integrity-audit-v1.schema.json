    "public_route_count_after",
    "sitemap_url_count_expected",
    "primary_layers_under_audit",
    "related_routes_checked",
    "walkthrough_scenarios",
    "total_scenarios",
    "scenarios_passed",
    "scenarios_failed",
    "repairs_applied",
    "boundary_regressions_found",
    "external_use_layer_coherence_confirmed",
    "reading_layer_integrity_confirmed",
    "retrieval_layer_integrity_confirmed",
    "citation_layer_integrity_confirmed",
    "source_use_layer_integrity_confirmed",
    "cross_layer_link_integrity_confirmed",
    "ai_agent_use_integrity_confirmed",
    "human_reader_use_integrity_confirmed",
    "route_count_drift_found",
    "stale_copy_found",
    "role_confusion_found",
    "link_imbalance_found",
    "authority_claim_drift_found",
    "verification_drift_found",
    "proof_drift_found",
    "detector_drift_found",
    "score_or_verdict_drift_found",
    "case_conclusion_drift_found",
    "generated_output_drift_found",
    "workflow_or_operational_drift_found",
    "transaction_or_sales_drift_found",
    "legal_or_financial_representation_drift_found",
    "new_decision_created",
    "route_registry_changed",
    "public_file_registry_changed",
    "sitemap_changed",
    "no_new_routes",
    "non_tool",
    "non_workflow",
    "non_operational",
    "non_authority_claim",
    "non_verification_claim",
    "non_proof",
    "non_detector",
    "non_scoring",
    "non_verdict",
    "non_case_conclusion",
    "non_generated_output",
    "non_transactional_review_surface"
