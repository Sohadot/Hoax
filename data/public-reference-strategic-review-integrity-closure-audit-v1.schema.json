{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hoax.ai/schemas/public-reference-strategic-review-integrity-closure-audit-v1.schema.json",
  "title": "Public Reference Strategic Review Integrity Closure Audit v1",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "sprint",
    "status",
    "audit_only",
    "phase",
    "phase_closure_candidate",
    "production_route_added",
    "public_route_count_before",
    "public_route_count_after",
    "sitemap_url_count_expected",
    "phase_3_components_checked",
    "phase_2_support_layers_checked",
    "walkthrough_scenarios",
    "total_scenarios",
    "scenarios_passed",
    "scenarios_failed",
    "strategic_review_integrity_confirmed",
    "phase_3_closure_recommended",
    "new_decision_created",
    "route_registry_changed",
    "public_file_registry_changed",
    "no_new_routes"
  ],
  "properties": {
    "id": { "const": "public-reference-strategic-review-integrity-closure-audit-v1" },
    "sprint": { "const": "Sprint 128" },
    "status": { "const": "public_reference_strategic_review_integrity_closure_audit" },
    "audit_only": { "const": true },
    "phase": { "const": "Phase 3" },
    "phase_closure_candidate": { "type": "boolean" },
    "production_route_added": { "const": false },
    "public_route_count_before": { "const": 104 },
    "public_route_count_after": { "const": 104 },
    "sitemap_url_count_expected": { "const": 104 },
    "walkthrough_scenarios": { "type": "array", "minItems": 28 },
    "total_scenarios": { "type": "integer", "minimum": 28 },
    "phase_3_closure_recommended": { "type": "boolean" },
    "new_decision_created": { "type": "boolean" },
    "route_registry_changed": { "const": false },
    "public_file_registry_changed": { "const": false },
    "no_new_routes": { "const": true }
  }
}
