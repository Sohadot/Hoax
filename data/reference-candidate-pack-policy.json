{
  "policy_id": "REF-CAND-PACK-POLICY-001",
  "name": "Hoax.ai Reference Candidate Pack Policy",
  "version": "v1.0.0",
  "status": "governed_internal_candidate_pack_policy",
  "maturity": "candidates_only_no_drafts_no_routes_no_publication",
  "governing_principle": "A candidate is not a page. It is a governed permission request for future reference value. The first candidate pack must prove discipline before it proves scale.",
  "allowed_candidate_actions": [
    "candidate_registration",
    "internal_candidate_record_creation",
    "candidate_pack_definition",
    "candidate_gate_scoping",
    "candidate_review_status_tracking"
  ],
  "prohibited_candidate_actions": [
    "public_pages",
    "draft_pages",
    "route_creation",
    "sitemap_expansion",
    "public_navigation",
    "public_metadata",
    "publication",
    "deployment",
    "dns",
    "cloudflare",
    "tool",
    "classifier",
    "upload",
    "scoring",
    "forms",
    "analytics",
    "external_factual_claims",
    "seo_expansion",
    "structured_data_on_public_surface"
  ],
  "required_candidate_fields": [
    "candidate_id",
    "candidate_name",
    "candidate_status",
    "page_family",
    "page_type_ref",
    "candidate_slug",
    "proposed_path",
    "route_status",
    "sitemap_status",
    "draft_status",
    "publication_status",
    "reference_thesis",
    "reference_purpose",
    "definition_scope_summary",
    "governance_boundary_summary",
    "system_relationships",
    "claim_scope",
    "source_scope",
    "semantic_seo_role",
    "prohibited_misreadings",
    "required_sections",
    "required_gates",
    "related_existing_governance_files",
    "future_internal_link_targets",
    "forbidden_public_implications",
    "review_status",
    "notes"
  ],
  "required_candidate_gates": [
    "PUB-GATE-0002",
    "PUB-GATE-0003",
    "PUB-GATE-0004",
    "PUB-GATE-0005",
    "PUB-GATE-0015",
    "PUB-GATE-0006",
    "PUB-GATE-0007",
    "PUB-GATE-0008",
    "PUB-GATE-0009",
    "PUB-GATE-0010",
    "PUB-GATE-0016",
    "PUB-GATE-0012",
    "PUB-GATE-0013",
    "PUB-GATE-0014"
  ],
  "candidate_status_rules": [
    "candidate_status_must_be_candidate_registered_or_proposed_internal",
    "route_status_must_be_not_route_created",
    "sitemap_status_must_be_not_sitemap_eligible",
    "draft_status_must_be_not_draft_created",
    "publication_status_must_be_publication_blocked"
  ],
  "non_authorization_rules": [
    "candidates_do_not_authorize_drafts",
    "candidates_do_not_authorize_routes",
    "candidates_do_not_authorize_sitemap",
    "candidates_do_not_authorize_publishing",
    "candidates_do_not_authorize_deployment",
    "candidates_do_not_authorize_seo_expansion"
  ],
  "last_reviewed": "2026-06-17"
}
