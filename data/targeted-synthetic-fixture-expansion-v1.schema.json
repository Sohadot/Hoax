{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hoax.ai/schemas/targeted-synthetic-fixture-expansion-v1.schema.json",
  "title": "Targeted Synthetic Fixture Expansion v1",
  "type": "object",
  "required": [
    "expansion_id",
    "version",
    "status",
    "decision_ref",
    "sprint",
    "public_route_authorized",
    "public_benchmark_authorized",
    "public_report_authorized",
    "output_generator_authorized",
    "scoring_authorized",
    "api_authorized",
    "javascript_authorized",
    "source_authority",
    "current_fixture_count_before",
    "max_fixture_count_after",
    "added_fixture_classes",
    "named_coverage_gaps_addressed",
    "fixture_admission_records",
    "coverage_delta",
    "remaining_gaps",
    "forbidden_fixture_classes",
    "operational_boundaries"
  ],
  "properties": {
    "expansion_id": {
      "type": "string",
      "const": "targeted-synthetic-fixture-expansion-v1"
    },
    "version": { "type": "string" },
    "status": {
      "type": "string",
      "const": "internal_non_public_targeted_fixture_expansion"
    },
    "decision_ref": {
      "type": "string",
      "const": "DEC-094"
    },
    "sprint": {
      "type": "string",
      "const": "Sprint 76"
    },
    "public_route_authorized": { "type": "boolean", "const": false },
    "public_benchmark_authorized": { "type": "boolean", "const": false },
    "public_report_authorized": { "type": "boolean", "const": false },
    "output_generator_authorized": { "type": "boolean", "const": false },
    "scoring_authorized": { "type": "boolean", "const": false },
    "api_authorized": { "type": "boolean", "const": false },
    "javascript_authorized": { "type": "boolean", "const": false },
    "source_authority": { "type": "array", "minItems": 7 },
    "current_fixture_count_before": { "type": "integer", "const": 10 },
    "max_fixture_count_after": { "type": "integer", "const": 16 },
    "added_fixture_classes": { "type": "array", "minItems": 6 },
    "named_coverage_gaps_addressed": { "type": "array", "minItems": 6 },
    "fixture_admission_records": { "type": "array", "minItems": 6 },
    "coverage_delta": { "type": "object" },
    "remaining_gaps": { "type": "array", "minItems": 1 },
    "forbidden_fixture_classes": { "type": "array", "minItems": 13 },
    "operational_boundaries": {
      "type": "object",
      "required": [
        "no_public_benchmark",
        "no_public_report",
        "no_public_engine",
        "no_output_generator",
        "no_upload",
        "no_scoring",
        "no_api",
        "no_javascript",
        "no_public_tool_behavior"
      ],
      "properties": {
        "no_public_benchmark": { "type": "boolean", "const": true },
        "no_public_report": { "type": "boolean", "const": true },
        "no_public_engine": { "type": "boolean", "const": true },
        "no_output_generator": { "type": "boolean", "const": true },
        "no_upload": { "type": "boolean", "const": true },
        "no_scoring": { "type": "boolean", "const": true },
        "no_api": { "type": "boolean", "const": true },
        "no_javascript": { "type": "boolean", "const": true },
        "no_public_tool_behavior": { "type": "boolean", "const": true }
      }
    }
  },
  "additionalProperties": true
}
