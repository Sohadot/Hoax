{
  "policy_id": "PUB-DRY-RUN-POLICY-001",
  "name": "Hoax.ai Publisher Dry-Run Policy",
  "version": "v1.0.0",
  "status": "governed_internal_publisher_dry_run_harness",
  "maturity": "candidate_logic_test_only_no_publication",
  "governing_principle": "The dry-run may test publisher logic. It must not create publishable content.",
  "refusal_principle": "A publisher is not trusted because it can generate. It is trusted because it can refuse.",
  "allowed_dry_run_actions": [
    "candidate_packet_validation",
    "state_transition_testing",
    "expected_pass_fail_testing",
    "refusal_behavior_testing",
    "gate_dependency_testing",
    "internal_case_simulation"
  ],
  "prohibited_dry_run_actions": [
    "page_creation",
    "draft_creation",
    "route_creation",
    "sitemap_expansion",
    "publishing",
    "deployment",
    "dns",
    "cloudflare",
    "forms",
    "analytics",
    "upload",
    "scoring",
    "classifier",
    "external_factual_claims",
    "candidate_registry_mutation",
    "queue_mutation",
    "public_seo_metadata_generation"
  ],
  "required_packet_fields": [
    "dry_run_case_id",
    "fictional",
    "candidate_shape_only",
    "page_family",
    "reference_thesis",
    "purpose_statement",
    "definition_scope_summary",
    "governance_boundary_summary",
    "claim_scope_summary",
    "source_scope_summary",
    "semantic_seo_role",
    "prohibited_misreading_notes",
    "requested_route_action",
    "requested_sitemap_action",
    "requested_draft_action",
    "expected_result",
    "expected_state"
  ],
  "required_failure_classes": [
    "route_creation_request",
    "sitemap_expansion_request",
    "draft_creation_before_approval",
    "missing_reference_thesis",
    "missing_claim_scope",
    "missing_source_scope",
    "missing_governance_boundary",
    "keyword_only_seo",
    "search_volume_first",
    "tool_implication",
    "upload_implication",
    "scoring_implication",
    "fake_real_framing",
    "subject_accusation",
    "unsupported_external_factual_claim",
    "unsupported_superiority",
    "direct_publication_request",
    "gate_bypass",
    "prohibited_schema_tool_service_product_language"
  ],
  "pass_meaning": "Packet shape satisfies dry-run logic and may proceed to future governance review only; no output authorized.",
  "non_authorization_rules": [
    "passing_dry_run_does_not_authorize_publishing",
    "passing_dry_run_does_not_authorize_drafts",
    "passing_dry_run_does_not_authorize_routes",
    "passing_dry_run_does_not_authorize_sitemap",
    "passing_dry_run_does_not_authorize_seo_expansion",
    "passing_dry_run_does_not_authorize_deployment",
    "passing_dry_run_does_not_add_real_candidates"
  ],
  "last_reviewed": "2026-06-17"
}
