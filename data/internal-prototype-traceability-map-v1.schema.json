{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hoax.ai/schemas/internal-prototype-traceability-map-v1.schema.json",
  "title": "Internal Prototype Traceability Map v1",
  "type": "object",
  "required": [
    "traceability_map_id",
    "version",
    "status",
    "decision_ref",
    "sprint",
    "public_route_authorized",
    "public_explanation_authorized",
    "report_generation_authorized",
    "output_generator_authorized",
    "scoring_authorized",
    "api_authorized",
    "javascript_authorized",
    "source_authority",
    "traceability_chain",
    "fixture_to_protocol_map",
    "protocol_to_standard_map",
    "boundary_to_caveat_map",
    "guardrail_to_forbidden_transformation_map",
    "required_internal_explanation_fields",
    "traceability_failure_conditions",
    "operational_boundaries"
  ],
  "properties": {
    "traceability_map_id": {
      "type": "string",
      "const": "internal-prototype-traceability-map-v1"
    },
    "version": { "type": "string" },
    "status": {
      "type": "string",
      "const": "internal_non_public_traceability_map"
    },
    "decision_ref": {
      "type": "string",
      "const": "DEC-092"
    },
    "sprint": {
      "type": "string",
      "const": "Sprint 74"
    },
    "public_route_authorized": { "type": "boolean", "const": false },
    "public_explanation_authorized": { "type": "boolean", "const": false },
    "report_generation_authorized": { "type": "boolean", "const": false },
    "output_generator_authorized": { "type": "boolean", "const": false },
    "scoring_authorized": { "type": "boolean", "const": false },
    "api_authorized": { "type": "boolean", "const": false },
    "javascript_authorized": { "type": "boolean", "const": false },
    "source_authority": {
      "type": "array",
      "allOf": [
        { "contains": { "const": "evidence_posture_standard_v1" } },
        { "contains": { "const": "evidence_posture_protocol_v1_draft" } },
        { "contains": { "const": "engine_boundary_charter" } },
        { "contains": { "const": "evidence_posture_engine_model_v0" } },
        { "contains": { "const": "output_language_guardrail_model_v1" } },
        { "contains": { "const": "internal_non_public_engine_prototype_charter" } },
        { "contains": { "const": "internal_prototype_fixture_policy" } },
        { "contains": { "const": "controlled_internal_prototype_v0_authorization_package" } },
        { "contains": { "const": "controlled_internal_prototype_v0_implementation" } },
        { "contains": { "const": "controlled_internal_prototype_v0_hardening" } }
      ]
    },
    "traceability_chain": { "type": "array", "minItems": 8 },
    "fixture_to_protocol_map": { "type": "object", "minProperties": 10 },
    "protocol_to_standard_map": { "type": "object", "minProperties": 17 },
    "boundary_to_caveat_map": { "type": "object", "minProperties": 8 },
    "guardrail_to_forbidden_transformation_map": { "type": "object", "minProperties": 10 },
    "required_internal_explanation_fields": { "type": "array", "minItems": 12 },
    "traceability_failure_conditions": { "type": "array", "minItems": 8 },
    "operational_boundaries": {
      "type": "object",
      "required": [
        "no_public_explanation",
        "no_report_generation",
        "no_public_engine",
        "no_output_generator",
        "no_upload",
        "no_scoring",
        "no_api",
        "no_javascript",
        "no_public_tool_behavior"
      ],
      "properties": {
        "no_public_explanation": { "type": "boolean", "const": true },
        "no_report_generation": { "type": "boolean", "const": true },
        "no_public_engine": { "type": "boolean", "const": true },
        "no_output_generator": { "type": "boolean", "const": true },
        "no_upload": { "type": "boolean", "const": true },
        "no_scoring": { "type": "boolean", "const": true },
        "no_api": { "type": "boolean", "const": true },
        "no_javascript": { "type": "boolean", "const": true },
        "no_public_tool_behavior": { "type": "boolean", "const": true }
      }
    }
  },
  "additionalProperties": true
}
